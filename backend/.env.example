# App Settings
APP_NAME=SETU
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# Clerk Authentication (Get from https://clerk.com)
CLERK_SECRET_KEY=your-clerk-secret-key-from-dashboard
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-from-dashboard

# LLM Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=mixtral-8x7b-32768
OPENAI_API_KEY=your-openai-api-key-as-fallback

# Google OAuth (for integrations, NOT user auth)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://localhost:8000/api/v1/auth/notion/callback

# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Database
DATABASE_URL=sqlite+aiosqlite:///./setu.db
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# Token encryption (optional; generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# NOTE: NO JWT_SECRET_KEY needed - Clerk handles tokens!

