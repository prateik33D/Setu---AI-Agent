# Frontend .env – copy to your React app root and fill in keys.

# Clerk (from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-from-dashboard

# Backend URLs (must match where you run the SETU backend)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
